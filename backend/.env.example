# Base de datos — usar SQLite para desarrollo, PostgreSQL para producción
# Desarrollo local (SQLite):
DATABASE_URL=sqlite:///dinamyt.db
# Producción (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/dinamyt

# JWT Secret — OBLIGATORIO en producción. Generar uno con:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CAMBIAR-POR-UN-VALOR-ALEATORIO-LARGO

# Flask — usar "production" al desplegar
FLASK_ENV=development
FLASK_DEBUG=1

# CORS — URL del frontend
FRONTEND_URL=http://localhost:3000

# Admin inicial — OBLIGATORIO cambiar la contraseña antes de desplegar.
# Si el admin ya existe en la base de datos, aplicar la nueva contraseña con:
#   flask reset-admin-password
ADMIN_EMAIL=admin@dinamyt.com
ADMIN_PASSWORD=CAMBIAR-POR-UNA-CONTRASENA-FUERTE
ADMIN_NOMBRE=Administrador DINAMYT

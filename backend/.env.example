# Base de datos — usar SQLite para desarrollo, PostgreSQL para producción
# Desarrollo local (SQLite):
DATABASE_URL=sqlite:///dinamyt.db
# Producción (PostgreSQL):
# DATABASE_URL=postgresql://user:password@host:5432/dinamyt

# JWT Secret — cambiar en producción
JWT_SECRET_KEY=dinamyt-dev-secret-key-change-in-production

# Flask
FLASK_ENV=development
FLASK_DEBUG=1

# CORS — URL del frontend
FRONTEND_URL=http://localhost:3000

# Admin inicial
ADMIN_EMAIL=admin@dinamyt.com
ADMIN_PASSWORD=Amy2026*
ADMIN_NOMBRE=Administrador DINAMYT
